# Eternal Website vault .gitignore
# Ignore build artifacts + deps inside the Astro site
site/node_modules/
site/dist/
site/.astro/
site/.env
site/.env.*

# Astro removed entirely
site/*

# OS / editor
.DS_Store
*.swp
*~
Thumbs.db

# Obsidian (keep local entirely)
.obsidian/
.obsidian/community-plugins.json
.obsidian/core-plugins.json
.obsidian/plugins/

# Editor / IDE
.vscode/
.idea/

# Internal docs / notes (not needed in repo)
notes/
Report.md
AGENTS.md

# Deployment config (no longer needed)
netlify.toml

# Backup / duplicate assets
*orig.bak*
*orig.bak-transparent*
client-templates/custom/*
client-templates/README.md

# DNS records / exports (local only)
*.csv
*.zip

# Non-site assets not needed for production
eternalwebsite.com (DNS Records) 3.csv
