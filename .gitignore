# Eternal Website vault .gitignore
# Ignore build artifacts + deps inside the Astro site
site/node_modules/
site/dist/
site/.astro/
site/.env
site/.env.*

# OS / editor
.DS_Store
*.swp
*~

# Obsidian (volatile workspace state - keep committed base but ignore runtime files)
.obsidian/workspace.json
.obsidian/graph.json
.obsidian/cache/

# Editor / IDE
.vscode/
.idea/

# Keep everything else (notes, Report, AGENTS, source) tracked.