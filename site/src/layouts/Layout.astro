---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<!-- Favicon: using the Eternal brand logo (square mark) instead of default Astro icon. Provides .ico for broad compat + PNG for modern. -->
		<link rel="icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" href="/favicon.png" sizes="512x512" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Built to Endure. Designed to Perform. Premium one-page websites for local businesses. Clean, fast, trustworthy design that builds credibility and generates leads." />
		<title>Eternal Website | Premium One-Page Sites for Local Businesses</title>

		<!-- Basic OG for sharing (enhance with real image later) -->
		<meta property="og:title" content="Eternal Website | Premium One-Page Sites for Local Businesses" />
		<meta property="og:description" content="Built to Endure. Designed to Perform. Clean, fast, professional one-page websites that help businesses look established and win more customers." />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://eternalwebsite.com" />
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
