---
interface Props {
  title: string;
  category: string;
  result: string;
  desc: string;
  image?: string;
  url: string;
}

const { title, category, result, desc, image, url } = Astro.props;
---

<a href={url} target="_blank" rel="noopener noreferrer" class="card overflow-hidden block group hover:border-[var(--accent)] transition-colors cursor-pointer no-underline text-inherit">
  {image && (
    <img
      src={image}
      alt={`${title} example`}
      class="w-full h-36 object-cover rounded-t-md border-b border-[var(--border)] -mx-6 -mt-6 mb-4"
      loading="lazy"
    />
  )}
  <div class="text-xs uppercase tracking-widest text-[var(--accent)] mb-1">{category}</div>
  <div class="font-semibold text-lg mb-1 group-hover:text-[var(--accent)] transition-colors">{title}</div>
  <div class="text-sm text-[var(--success)] font-medium mb-3">{result}</div>
  <p class="text-sm text-[var(--text-muted)]">{desc}</p>
  <div class="mt-3 text-xs font-medium text-[var(--accent)] opacity-0 group-hover:opacity-100 transition-opacity">View site →</div>
</a>
