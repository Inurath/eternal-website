---
interface Props {
  icon: string;
  title: string;
  desc: string;
  slug: string;
}

const { icon, title, desc, slug } = Astro.props;
---

<a href={`/services/${slug}`} class="card h-full flex flex-col group hover:border-[var(--accent)] transition-colors cursor-pointer no-underline text-inherit">
  <div class="text-3xl mb-3" aria-hidden="true">{icon}</div>
  <h3 class="font-semibold mb-2 group-hover:text-[var(--accent)] transition-colors">{title}</h3>
  <p class="text-[var(--text-muted)] text-sm flex-1">{desc}</p>
  <div class="mt-4 text-xs font-medium text-[var(--accent)] opacity-0 group-hover:opacity-100 transition-opacity">Learn more →</div>
</a>
