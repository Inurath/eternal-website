---
interface Props {
  icon: string;
  title: string;
  desc: string;
}

const { icon, title, desc } = Astro.props;
---

<div class="card h-full flex flex-col">
  <div class="text-3xl mb-3" aria-hidden="true">{icon}</div>
  <h3 class="font-semibold mb-2">{title}</h3>
  <p class="text-[var(--text-muted)] text-sm flex-1">{desc}</p>
</div>