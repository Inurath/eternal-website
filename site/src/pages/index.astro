---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import PricingCard from '../components/PricingCard.astro';
import PortfolioCard from '../components/PortfolioCard.astro';

import { services } from '../data/services';
import { pricingTiers } from '../data/pricing';
import { portfolio } from '../data/portfolio';
import { testimonials } from '../data/testimonials';
---

<Layout>
	<!-- Navbar (sticky, professional, always visible on scroll with solid background) -->
	<nav class="fixed top-0 z-50 w-full bg-[var(--surface)] border-b border-[var(--border)]">
		<div class="container flex items-center justify-between py-4">
			<a href="#hero" class="flex items-center gap-2 font-bold text-xl tracking-tight text-[var(--accent)]">
				<img src="/eternal-logo-with-name.png" alt="Eternal Website" class="h-12 w-auto" />
			</a>
			
			<div class="hidden md:flex items-center gap-8 text-sm font-medium">
				<a href="#services" class="hover:text-[var(--accent)] transition-colors">Services</a>
				<a href="#pricing" class="hover:text-[var(--accent)] transition-colors">Pricing</a>
				<a href="#work" class="hover:text-[var(--accent)] transition-colors">Work</a>
				<a href="#about" class="hover:text-[var(--accent)] transition-colors">About</a>
				<a href="#contact" class="hover:text-[var(--accent)] transition-colors">Contact</a>
			</div>

			<div class="flex items-center gap-3">
				<button id="dark-toggle" title="Toggle dark mode" aria-label="Toggle dark mode"></button>
				<a href="#contact" class="btn btn-primary text-sm">Get a quote</a>
			</div>
		</div>
	</nav>

	<script>
		// Robust dark mode: persist + system pref + reliable toggle (no onclick timing issues)
		function updateDarkToggle() {
			const toggle = document.getElementById('dark-toggle');
			if (!toggle) return;
			toggle.textContent = document.documentElement.classList.contains('dark') ? '☀️' : '🌙';
		}

		function toggleDarkMode() {
			document.documentElement.classList.toggle('dark');
			const isDark = document.documentElement.classList.contains('dark');
			localStorage.setItem('theme', isDark ? 'dark' : 'light');
			updateDarkToggle();
		}

		function initTheme() {
			// Apply saved or system preference
			const saved = localStorage.getItem('theme');
			if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
				document.documentElement.classList.add('dark');
			}
			updateDarkToggle();

			// Attach click listener (more reliable than inline onclick)
			const toggle = document.getElementById('dark-toggle');
			if (toggle) {
				toggle.addEventListener('click', toggleDarkMode);
			}
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', initTheme);
		} else {
			initTheme();
		}
	</script>

	<!-- Hero -->
	<header id="hero" class="section pt-28 pb-20 bg-[var(--surface)] border-b border-[var(--border)]">
		<div class="container text-center max-w-3xl mx-auto">
			<div class="inline-block px-3 py-1 rounded-full text-xs font-semibold tracking-widest mb-4 bg-[var(--accent)] text-white">FOR SMALL LOCAL BUSINESSES</div>
			
			<h1 class="mb-4">Timeless websites<br>that build trust and last.</h1>
			<p class="text-xl text-[var(--text-muted)] mb-8 max-w-xl mx-auto">
				Premium one-page sites for local businesses. Clean, fast, professional - designed to generate leads and make you look like the obvious choice.
			</p>

			<div class="flex flex-col sm:flex-row gap-3 justify-center">
				<a href="#pricing" class="btn btn-primary text-base px-8">See pricing</a>
				<a href="#contact" class="btn btn-secondary text-base px-8">Get a quote</a>
			</div>
			<p class="mt-4 text-xs text-[var(--text-muted)]">Bradenton / Sarasota, FL - 1-2 week delivery</p>
		</div>
	</header>

	<!-- Trust row (in a clear box for visual separation) -->
	<div class="py-4 section-box border-b border-[var(--border)]">
		<div class="container flex flex-wrap justify-center gap-x-8 gap-y-2 text-xs uppercase tracking-[2px] text-[var(--text-muted)]">
			<div>100% Custom - No Templates</div>
			<div>Mobile-First &amp; Fast</div>
			<div>Basic SEO Included</div>
			<div>30-Day Revisions</div>
		</div>
	</div>

	<!-- Services -->
	<section id="services" class="section py-16 container">
		<div class="max-w-2xl mb-10">
			<h2>Everything you need on one page.</h2>
			<p class="text-[var(--text-muted)]">No bloated 15-page corporate site. Just the essentials that make small businesses look established and convert visitors into customers.</p>
		</div>

		<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
			{services.map((s) => <ServiceCard icon={s.icon} title={s.title} desc={s.desc} />)}
		</div>
	</section>

	<!-- Pricing -->
	<section id="pricing" class="section py-16 bg-[var(--surface)] border-y border-[var(--border)]">
		<div class="container">
			<div class="max-w-2xl mb-10">
				<h2>Simple, transparent pricing.</h2>
				<p class="text-[var(--text-muted)]">One project fee. No hourly billing surprises. Includes mobile, basic SEO, contact form, and launch support.</p>
			</div>

			<div class="grid md:grid-cols-3 gap-6 max-w-5xl">
				{pricingTiers.map((t) => (
					<PricingCard
						name={t.name}
						price={t.price}
						period={t.period}
						popular={t.popular}
						features={t.features}
						cta={t.cta}
					/>
				))}
			</div>
		</div>
	</section>

	<!-- Work / Portfolio -->
	<section id="work" class="section py-16 container">
		<div class="max-w-2xl mb-10">
			<h2>Real results for local businesses like yours.</h2>
		</div>
		<div class="grid md:grid-cols-2 gap-6">
			{portfolio.map((p) => (
				<PortfolioCard
					title={p.title}
					category={p.category}
					result={p.result}
					desc={p.desc}
					image={p.image}
				/>
			))}
		</div>
		<p class="text-xs text-center mt-6 text-[var(--text-muted)]">More examples available upon request. All work is custom and client-approved.</p>
	</section>

	<!-- Testimonials (new from research - trust signal) -->
	<section class="section py-12 bg-[var(--surface-2)] border-y border-[var(--border)]">
		<div class="container max-w-4xl">
			<div class="grid md:grid-cols-3 gap-6">
				{testimonials.map((t) => (
					<div class="card text-sm">
						<p class="italic mb-4">"{t.quote}"</p>
						<div class="font-medium">{t.name}</div>
						<div class="text-xs text-[var(--text-muted)]">{t.role}, {t.business}</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- About -->
	<section id="about" class="section py-16 bg-[var(--surface)] border-y border-[var(--border)]">
		<div class="container max-w-3xl">
			<h2 class="mb-4">Built for small businesses that actually need a website.</h2>
			<div class="prose text-[var(--text-muted)]">
				<p>The Eternal Website team is based in the Bradenton / Sarasota area. We build websites the way we wish every small business had when we started - professional enough to win trust, simple enough to actually use, and fast enough to load before a customer gets impatient. We specialize in one-page sites but can also build multi-page websites as needed.</p>
				<p>No jargon. No 20-page corporate bloat. Just a clean, trustworthy online presence that makes you the obvious choice in your town.</p>
			</div>
		</div>
	</section>

	<!-- Contact -->
	<section id="contact" class="section py-16 container">
		<div class="max-w-xl mx-auto">
			<h2 class="text-center mb-2">Ready to get a site that lasts?</h2>
			<p class="text-center text-[var(--text-muted)] mb-8">Tell the Eternal Website team about your business. We reply within 24 hours.</p>

			<!-- Form: JS-enhanced with mailto fallback (real service in polish) -->
			<form id="contact-form" class="space-y-4">
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
					<div>
						<label for="name">Your name</label>
						<input type="text" id="name" name="name" required>
					</div>
					<div>
						<label for="business">Business name</label>
						<input type="text" id="business" name="business" required>
					</div>
				</div>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
					<div>
						<label for="email">Email</label>
						<input type="email" id="email" name="email" required>
					</div>
					<div>
						<label for="phone">Phone (optional)</label>
						<input type="tel" id="phone" name="phone">
					</div>
				</div>
				<div>
					<label for="message">What are you looking for? (type of business, timeline, any must-haves)</label>
					<textarea id="message" name="message" rows="5" required></textarea>
				</div>

				<button type="submit" class="btn btn-primary w-full text-base">Send inquiry</button>

				<div id="form-success" class="hidden p-4 bg-[var(--surface)] border border-[var(--success)] rounded text-sm text-[var(--success)]">
					Thanks! Your email client should open with the details pre-filled. If it doesn't, just email <a href="mailto:info@eternalwebsite.com" class="font-medium underline">info@eternalwebsite.com</a> directly.
				</div>

				<p class="text-[10px] text-center text-[var(--text-muted)]">Or email <a href="mailto:info@eternalwebsite.com" class="font-medium">info@eternalwebsite.com</a> directly.</p>
			</form>

			<script>
				const form = document.getElementById('contact-form');
				const success = document.getElementById('form-success');

				form?.addEventListener('submit', (e) => {
					e.preventDefault();

					const name = (document.getElementById('name') as HTMLInputElement).value;
					const business = (document.getElementById('business') as HTMLInputElement).value;
					const email = (document.getElementById('email') as HTMLInputElement).value;
					const phone = (document.getElementById('phone') as HTMLInputElement).value;
					const msg = (document.getElementById('message') as HTMLTextAreaElement).value;

					const subject = encodeURIComponent(`Website inquiry - ${business}`);
					const body = encodeURIComponent(
						`Name: ${name}\nBusiness: ${business}\nEmail: ${email}\nPhone: ${phone || 'N/A'}\n\n${msg}`
					);

					// Open mailto to the team address
					window.location.href = `mailto:info@eternalwebsite.com?subject=${subject}&body=${body}`;

					// Show friendly success (in case mailto is blocked or user wants confirmation)
					if (success) {
						success.classList.remove('hidden');
						form?.querySelector('button')?.classList.add('opacity-50', 'pointer-events-none');
					}
				});
			</script>
		</div>
	</section>

	<footer class="py-8 border-t text-xs text-center text-[var(--text-muted)]">
		<div class="flex items-center justify-center gap-3 mb-2">
			<!-- X (functional link) -->
			<a href="https://x.com/Eternalwebsite" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-[var(--border)] bg-[var(--surface)] overflow-hidden transition hover:border-[var(--accent)]" aria-label="Follow on X" title="Follow @Eternalwebsite on X">
				<img src="/x-logo.jpg" alt="X" class="w-full h-full object-cover" />
			</a>

			<!-- Instagram (visual only, no link yet) -->
			<span class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-[var(--border)] bg-[var(--surface)] overflow-hidden transition hover:border-[var(--accent)]" title="Instagram (coming soon)">
				<img src="/instagram-logo.jpg" alt="Instagram" class="w-full h-full object-cover" />
			</span>

			<!-- Facebook (visual only, no link yet) -->
			<span class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-[var(--border)] bg-[var(--surface)] overflow-hidden transition hover:border-[var(--accent)]" title="Facebook (coming soon)">
				<img src="/facebook-logo.png" alt="Facebook" class="w-full h-full object-cover" />
			</span>
		</div>
		© 2026 Eternal Website. Bradenton/Sarasota, Florida. All sites are custom-built and hand-crafted.
	</footer>
</Layout>
