---
import Layout from '../../layouts/Layout.astro';
import { pricingTiers } from '../../data/pricing';

export function getStaticPaths() {
  return pricingTiers.map((t) => ({
    params: { slug: t.slug },
    props: { tier: t },
  }));
}

const { tier } = Astro.props;
---

<Layout>
  <!-- Minimal nav for sub-pages -->
  <nav class="fixed top-0 z-50 w-full bg-[var(--surface)] border-b border-[var(--border)]">
    <div class="container flex items-center justify-between py-4">
      <a href="/" class="flex items-center gap-2 font-bold text-xl tracking-tight text-[var(--accent)]">
        <img src="/eternal-logo-with-name.png" alt="Eternal Website" class="h-12 w-auto" />
      </a>
      <div class="flex items-center gap-4">
        <button id="dark-toggle" title="Toggle dark mode" aria-label="Toggle dark mode"></button>
        <a href="/#pricing" class="text-sm font-medium text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors">← Back to pricing</a>
      </div>
    </div>
  </nav>

  <script>
    function updateDarkToggle() {
      const toggle = document.getElementById('dark-toggle');
      if (!toggle) return;
      toggle.textContent = document.documentElement.classList.contains('dark') ? '☀️' : '🌙';
    }
    function toggleDarkMode() {
      document.documentElement.classList.toggle('dark');
      const isDark = document.documentElement.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateDarkToggle();
    }
    function initTheme() {
      const saved = localStorage.getItem('theme');
      if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
      updateDarkToggle();
      const toggle = document.getElementById('dark-toggle');
      if (toggle) toggle.addEventListener('click', toggleDarkMode);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTheme);
    } else {
      initTheme();
    }
  </script>

  <main class="pt-28 pb-20">
    <div class="container max-w-2xl mx-auto">
      <!-- Breadcrumb -->
      <div class="text-xs text-[var(--text-muted)] mb-8">
        <a href="/" class="hover:text-[var(--accent)]">Home</a>
        <span class="mx-2">›</span>
        <a href="/#pricing" class="hover:text-[var(--accent)]">Pricing</a>
        <span class="mx-2">›</span>
        <span>{tier.name}</span>
      </div>

      <!-- Header -->
      {tier.popular && (
        <div class="inline-block px-3 py-1 rounded-full text-xs font-semibold tracking-widest mb-4 bg-[var(--accent)] text-white">MOST POPULAR</div>
      )}
      <h1 class="mb-2">{tier.name}</h1>
      <div class="flex items-baseline gap-2 mb-6">
        <span class="text-4xl font-bold tracking-tighter">{tier.price}</span>
        <span class="text-[var(--text-muted)]">/ {tier.period}</span>
      </div>
      <p class="text-lg text-[var(--text-muted)] mb-10">{tier.detail.intro}</p>

      <!-- Example image -->
      <div class="mb-10 rounded-xl overflow-hidden border border-[var(--border)]">
        <img
          src={tier.detail.image}
          alt={`${tier.name} plan example`}
          class="w-full object-contain"
        />
        <div class="px-4 py-2 bg-[var(--surface)] text-xs text-[var(--text-muted)]">Example of work at this tier</div>
      </div>

      <!-- Detail bullets -->
      <div class="card mb-10">
        <h2 class="text-lg font-semibold mb-4">Everything included</h2>
        <ul class="space-y-3">
          {tier.detail.bullets.map((b) => (
            <li class="flex gap-3 text-sm text-[var(--text-muted)]">
              <span class="text-[var(--accent)] mt-0.5 flex-shrink-0">✓</span>
              <span>{b}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Closing paragraph -->
      <p class="text-[var(--text-muted)] mb-10">{tier.detail.closing}</p>

      <!-- CTA -->
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="/#contact" class={`btn ${tier.popular ? 'btn-primary' : 'btn-secondary'} text-base px-8`}>
          Get a quote for {tier.name}
        </a>
        <a href="/#pricing" class="btn btn-secondary text-base px-8">← Compare plans</a>
      </div>
    </div>
  </main>

  <footer class="py-6 border-t text-xs text-center text-[var(--text-muted)]">
    © 2026 Eternal Website. Bradenton/Sarasota, Florida.
  </footer>
</Layout>
